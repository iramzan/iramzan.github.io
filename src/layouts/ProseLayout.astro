---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  meta?: string;
  independent?: boolean;
}

const { title, description, eyebrow, meta, independent = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto w-full max-w-3xl px-6 py-14 sm:py-20">
    <header class="mb-10">
      <p class="eyebrow"># {eyebrow}</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        {
          meta && (
            <span class="rounded-md border border-line bg-surface px-2.5 py-1 font-mono text-xs text-muted">
              {meta}
            </span>
          )
        }
        {
          independent && (
            <span class="rounded-md border border-accent/40 bg-accent-tint px-2.5 py-1 font-mono text-xs text-accent">
              independent work — not delivered for an employer
            </span>
          )
        }
      </div>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
