---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';
---

<BaseLayout title="Page not found" description="This page doesn't exist.">
  <section class="mx-auto flex w-full max-w-3xl flex-col items-start px-6 py-24">
    <p class="eyebrow"># 404</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Page not found</h1>
    <p class="mt-4 leading-relaxed text-muted">
      That page doesn't exist. It may have moved, or the link may be out of date.
    </p>
    <a
      href={withBase('/')}
      class="mt-8 rounded-md bg-accent px-4 py-2 text-sm font-medium text-bg hover:opacity-90"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
