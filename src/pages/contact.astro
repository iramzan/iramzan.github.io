---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

const channels = [
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/imranramzan',
    href: SITE.linkedin,
    note: 'Profile, history, and recommendations.',
  },
  {
    label: 'Email',
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    note: 'The fastest way to reach me.',
  },
  {
    label: 'Mobile',
    value: SITE.phone,
    href: `tel:${SITE.phone.replace(/\s+/g, '')}`,
    note: 'Call directly.',
  },
  {
    label: 'WhatsApp',
    value: SITE.phone,
    href: SITE.whatsapp,
    note: 'Message me on WhatsApp.',
  },

];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Imran Ramzan — email and LinkedIn."
>
  <section class="mx-auto w-full max-w-3xl px-6 py-14 sm:py-20">
    <p class="eyebrow"># contact</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Contact</h1>
    <p class="mt-4 leading-relaxed text-muted">
      Based in Abu Dhabi, open to AI infrastructure and platform engineering leadership roles
      across the GCC.
    </p>

    <ul class="mt-10 space-y-4">
      {
        channels.map((c) => (
          <li>
            <a
              href={c.href}
              target={c.href.startsWith('mailto:') || c.href.startsWith('tel:') ? undefined : '_blank'}
              rel={c.href.startsWith('mailto:') || c.href.startsWith('tel:') ? undefined : 'noopener'}
              class="group flex flex-col gap-1 rounded-lg border border-line bg-surface p-5 transition-colors hover:border-accent"
            >
              <span class="font-mono text-xs text-muted">{c.label}</span>
              <span class="font-medium group-hover:text-accent">{c.value}</span>
              <span class="text-sm text-muted">{c.note}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
