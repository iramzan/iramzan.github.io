---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';

const caseStudies = (await getCollection('case-studies')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Case Studies"
  description="Case studies in platform engineering: scaling Kubernetes 40×, standing up a second cloud, FinOps at $10M+ scale, and AI platform foundations."
>
  <section class="mx-auto w-full max-w-5xl px-6 py-14 sm:py-20">
    <p class="eyebrow"># case-studies</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Case Studies</h1>
    <p class="mt-4 max-w-3xl leading-relaxed text-muted">
      Each one follows the same structure — context, constraints, what I did, outcome, and what
      I'd do differently. Consulting clients are described generically.
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        caseStudies.map((cs) => (
          <CaseStudyCard
            slug={cs.id}
            title={cs.data.title}
            summary={cs.data.summary}
            metric={cs.data.metric}
            independent={cs.data.independent}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
