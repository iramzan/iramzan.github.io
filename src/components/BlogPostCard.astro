---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { withBase } from '../utils/url';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  cover?: ImageMetadata;
}

const { slug, title, description, pubDate, cover } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<a
  href={withBase(`/blog/${slug}/`)}
  class="group flex h-full flex-col overflow-hidden rounded-lg border border-line bg-surface transition-colors hover:border-accent"
>
  {
    cover && (
      <Image
        src={cover}
        alt={title}
        class="h-40 w-full object-cover"
        widths={[300, 600]}
        sizes="(min-width: 640px) 33vw, 100vw"
      />
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <p class="font-mono text-xs text-muted">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </p>
    <h3 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-accent">
      {title}
    </h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{description}</p>
    <p class="mt-4 font-mono text-xs text-muted group-hover:text-accent">read post →</p>
  </div>
</a>
