---
import ThemeToggle from './ThemeToggle.astro';
import { SITE } from '../consts';
import { withBase } from '../utils/url';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const current = Astro.url.pathname.replace(base, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href.replace(/\/$/, ''));
}
---

<header class="sticky top-0 z-40 border-b border-line bg-bg/85 backdrop-blur">
  <div class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 px-6 py-3.5">
    <a href={withBase('/')} class="text-sm font-semibold tracking-tight hover:text-accent">
      {SITE.name}
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      <nav aria-label="Main">
        <ul class="flex items-center gap-0.5 sm:gap-1">
          {
            nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'rounded-md px-2 py-1.5 text-sm sm:px-2.5',
                    isActive(item.href)
                      ? 'font-medium text-accent'
                      : 'text-muted hover:text-ink',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
